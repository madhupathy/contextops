{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextOps Trace Schema",
  "description": "Canonical schema for AI agent run traces",
  "type": "object",
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "Tenant identifier for multi-tenant isolation"
    },
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this run"
    },
    "user": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "groups": { "type": "array", "items": { "type": "string" } }
      }
    },
    "agent": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "input": {
      "type": "object",
      "properties": {
        "query": { "type": "string", "description": "The user's query or instruction" }
      },
      "required": ["query"]
    },
    "retrieval": {
      "type": "object",
      "properties": {
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "doc_id": { "type": "string" },
              "title": { "type": "string" },
              "score": { "type": "number" },
              "acl_passed": { "type": "boolean" },
              "acl_reason": { "type": "string" },
              "selected": { "type": "boolean" }
            },
            "required": ["doc_id"]
          }
        },
        "selected": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "memory_id": { "type": "string" },
              "type": { "type": "string", "enum": ["conversation", "episodic", "semantic", "entity", "preference", "task"] },
              "summary": { "type": "string" },
              "content": { "type": "string" },
              "relevance_score": { "type": "number" },
              "is_stale": { "type": "boolean" },
              "stale_reason": { "type": "string" },
              "selected": { "type": "boolean" }
            },
            "required": ["memory_id"]
          }
        },
        "selected": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "permissions": {
      "type": "object",
      "properties": {
        "acl_filters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "doc_id": { "type": "string" },
              "result": { "type": "string", "enum": ["passed", "filtered"] },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "args": { "type": "object" },
          "status": { "type": "string", "enum": ["success", "failure", "timeout", "skipped"] },
          "result": {},
          "latency_ms": { "type": "integer" }
        },
        "required": ["name"]
      }
    },
    "reasoning_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step": { "type": "integer" },
          "type": { "type": "string", "enum": ["think", "retrieve", "remember", "tool_call", "tool_result", "generate", "decide", "act"] },
          "content": { "type": "string" }
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "final_answer": { "type": "string" },
        "citations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "expected_answer": { "type": "string" },
    "expected_sources": { "type": "array", "items": { "type": "string" } },
    "expected_tools": { "type": "array", "items": { "type": "string" } },
    "metrics": {
      "type": "object",
      "properties": {
        "latency_ms": { "type": "integer" },
        "prompt_tokens": { "type": "integer" },
        "completion_tokens": { "type": "integer" },
        "total_tokens": { "type": "integer" },
        "estimated_cost": { "type": "number" }
      }
    }
  }
}
