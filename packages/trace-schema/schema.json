{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ContextOps Trace Schema",
    "description": "Canonical schema for AI agent run traces",
    "type": "object",
    "properties": {
        "tenant_id": {
            "type": "string",
            "description": "Tenant identifier for multi-tenant isolation"
        },
        "run_id": {
            "type": "string",
            "description": "Unique identifier for this run"
        },
        "user": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "role": {
                    "type": "string"
                },
                "groups": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "agent": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                },
                "version": {
                    "type": "string"
                }
            }
        },
        "input": {
            "type": "object",
            "properties": {
                "query": {
                    "type": "string",
                    "description": "The user's query or instruction"
                }
            },
            "required": [
                "query"
            ]
        },
        "retrieval": {
            "type": "object",
            "properties": {
                "candidates": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "doc_id": {
                                "type": "string"
                            },
                            "title": {
                                "type": "string"
                            },
                            "score": {
                                "type": "number"
                            },
                            "acl_passed": {
                                "type": "boolean"
                            },
                            "acl_reason": {
                                "type": "string"
                            },
                            "selected": {
                                "type": "boolean"
                            }
                        },
                        "required": [
                            "doc_id"
                        ]
                    }
                },
                "selected": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "memory": {
            "type": "object",
            "properties": {
                "candidates": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "memory_id": {
                                "type": "string"
                            },
                            "type": {
                                "type": "string",
                                "enum": [
                                    "conversation",
                                    "episodic",
                                    "semantic",
                                    "entity",
                                    "preference",
                                    "task"
                                ]
                            },
                            "summary": {
                                "type": "string"
                            },
                            "content": {
                                "type": "string"
                            },
                            "relevance_score": {
                                "type": "number"
                            },
                            "is_stale": {
                                "type": "boolean"
                            },
                            "stale_reason": {
                                "type": "string"
                            },
                            "selected": {
                                "type": "boolean"
                            },
                            "source_doc_id": {
                                "type": "string",
                                "description": "Original document this memory was extracted from"
                            },
                            "source_acl_blocked": {
                                "type": "boolean",
                                "description": "Whether the source document is ACL-restricted"
                            }
                        },
                        "required": [
                            "memory_id"
                        ]
                    }
                },
                "selected": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "permissions": {
            "type": "object",
            "properties": {
                "acl_filters": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "doc_id": {
                                "type": "string"
                            },
                            "result": {
                                "type": "string",
                                "enum": [
                                    "passed",
                                    "filtered"
                                ]
                            },
                            "reason": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "tools": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "args": {
                        "type": "object"
                    },
                    "status": {
                        "type": "string",
                        "enum": [
                            "success",
                            "failure",
                            "timeout",
                            "skipped"
                        ]
                    },
                    "result": {},
                    "latency_ms": {
                        "type": "integer"
                    }
                },
                "required": [
                    "name"
                ]
            }
        },
        "reasoning_steps": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "step": {
                        "type": "integer"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "think",
                            "retrieve",
                            "remember",
                            "tool_call",
                            "tool_result",
                            "generate",
                            "decide",
                            "act"
                        ]
                    },
                    "content": {
                        "type": "string"
                    },
                    "node_id": {
                        "type": "string",
                        "description": "For graph-based agents (LangGraph): the node name this step ran in."
                    },
                    "edge_condition": {
                        "type": "string",
                        "description": "For conditional edges: the condition that routed to the next node."
                    },
                    "is_cycle": {
                        "type": "boolean",
                        "description": "True if this step is part of an intentional cycle/loop in the graph."
                    }
                }
            }
        },
        "output": {
            "type": "object",
            "properties": {
                "final_answer": {
                    "type": "string"
                },
                "citations": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "expected_answer": {
            "type": "string"
        },
        "expected_sources": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "expected_tools": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "metrics": {
            "type": "object",
            "properties": {
                "latency_ms": {
                    "type": "integer"
                },
                "prompt_tokens": {
                    "type": "integer"
                },
                "completion_tokens": {
                    "type": "integer"
                },
                "total_tokens": {
                    "type": "integer"
                },
                "estimated_cost": {
                    "type": "number"
                }
            }
        },
        "parent_run_id": {
            "type": "string",
            "description": "If this run was spawned by an orchestrator, the parent run's ID. Enables multi-agent DAG reconstruction."
        },
        "agent_role": {
            "type": "string",
            "enum": [
                "orchestrator",
                "subagent",
                "specialist",
                "planner",
                "executor",
                "evaluator",
                "standalone"
            ],
            "description": "The role this agent played in the overall task. Used to group and analyse multi-agent systems."
        },
        "session_id": {
            "type": "string",
            "description": "Groups all runs belonging to one user session or long-horizon task across multiple turns."
        },
        "task_id": {
            "type": "string",
            "description": "Groups all runs that are part of one autonomous task, even across multiple sessions."
        },
        "plan": {
            "type": "object",
            "description": "For plan-and-execute agents: the plan created at the start of this run.",
            "properties": {
                "steps": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "step_id": {
                                "type": "string"
                            },
                            "description": {
                                "type": "string"
                            },
                            "completed": {
                                "type": "boolean"
                            },
                            "assigned_to": {
                                "type": "string",
                                "description": "Agent ID assigned to this step"
                            }
                        }
                    }
                },
                "total_steps": {
                    "type": "integer"
                },
                "completed_steps": {
                    "type": "integer"
                }
            }
        },
        "handoffs": {
            "type": "array",
            "description": "Records of control transfer to/from other agents.",
            "items": {
                "type": "object",
                "properties": {
                    "to_agent": {
                        "type": "string"
                    },
                    "from_agent": {
                        "type": "string"
                    },
                    "reason": {
                        "type": "string"
                    },
                    "context_passed": {
                        "type": "object"
                    },
                    "timestamp": {
                        "type": "string"
                    }
                }
            }
        }
    }
}