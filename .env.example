# ContextOps Environment Configuration
# Copy to .env and edit as needed

# ── Database ──────────────────────────────────────────
POSTGRES_USER=contextops
POSTGRES_PASSWORD=contextops
POSTGRES_DB=contextops

# ── API Service ───────────────────────────────────────
PORT=8080
DATABASE_URL=postgres://contextops:contextops@localhost:5432/contextops?sslmode=disable
REDIS_URL=redis://localhost:6379/0
GIN_MODE=debug

# ── Evaluator Service ────────────────────────────────
# Required for LLM-as-judge evaluators (optional, falls back to heuristics)
OPENAI_API_KEY=

# ── Web UI ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_EVALUATOR_URL=http://localhost:8081

# ── CLI ───────────────────────────────────────────────
CONTEXTOPS_API_URL=http://localhost:8080
CONTEXTOPS_TENANT=00000000-0000-0000-0000-000000000001
